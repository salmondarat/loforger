{
  "id": "nextjs-supabase-mvp",
  "name": "Next.js + Supabase MVP",
  "description": "Fast SaaS starter with Next.js and Supabase",
  "mode": "mvp",
  "requiredAnswers": {
    "frontend.framework": "nextjs",
    "database.primary": "supabase"
  },
  "files": [
    {
      "path": "package.json",
      "template": "package.json.hbs"
    },
    {
      "path": "README.md",
      "template": "README.md.hbs"
    },
    {
      "path": ".env.example",
      "template": "env.example.hbs"
    },
    {
      "path": "next.config.js",
      "template": "next.config.js"
    },
    {
      "path": "tsconfig.json",
      "template": "tsconfig.json"
    },
    {
      "path": "src/app/layout.tsx",
      "template": "layout.tsx.hbs"
    },
    {
      "path": "src/app/page.tsx",
      "template": "page.tsx.hbs"
    },
    {
      "path": "src/app/globals.css",
      "template": "globals.css"
    }
  ],
  "postGenerate": {
    "instructions": [
      "1. Copy .env.example to .env.local",
      "2. Add your Supabase credentials from https://supabase.com",
      "3. Run 'npm install' to install dependencies",
      "4. Run 'npm run dev' to start development server"
    ]
  }
}
